#!/usr/bin/env bash

# Fastfetch конфиг
if [[ ! -f ~/.config/fastfetch/config.jsonc ]]; then
    mkdir -p ~/.config/fastfetch
    cat > ~/.config/fastfetch/config.jsonc << 'EOF'
{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "auto",
    "padding": {
      "top": 0,
      "left": 2,
      "right": 2
    }
  },
  "display": {
    "separator": ": ",
    "key": {
      "width": 8
    }
  },
  "modules": [
    {
      "type": "cpu",
      "key": "CPU",
      "temp": false,
      "showPeCoreCount": true
    },
    {
      "type": "gpu",
      "key": "GPU"
    },
    {
      "type": "memory",
      "key": "ОЗУ"
    },
    {
      "type": "os",
      "key": "ОС"
    },
    {
      "type": "disk",
      "key": "Память",
      "folders": "/storage"
    },
    "break",
    {
      "type": "shell",
      "key": "Shell"
    },
    {
      "type": "uptime",
      "key": "Аптайм"
    },
    {
      "type": "kernel",
      "key": "Kernel"
    }
  ]
}
EOF
fi