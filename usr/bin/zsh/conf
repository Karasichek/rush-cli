#!/usr/bin/env zsh

# Подключаем общие функции
COMMON_FUNCS="${HOME}/usr/bin/common_functions.sh"
[ -f "$COMMON_FUNCS" ] && . "$COMMON_FUNCS"

rush() {
    case "$1" in
        update)
            local repo_dir="${HOME}/rush-cli"
            [ ! -d "$repo_dir" ] && echo "Репозиторий не найден" && return 1
            (
                cd "$repo_dir" || exit 1
                git fetch origin master 2>/dev/null
                LOCAL=$(git rev-parse @)
                REMOTE=$(git rev-parse origin/master)
                if [[ "$LOCAL" == "$REMOTE" ]]; then
                    echo "Актуальная версия."
                else
                    git pull origin master
                    echo "Обновлено. Выполните: reload"
                fi
            )
            ;;
        *) echo "Использование: rush update" ;;
    esac
}

creature() {
    local name="$1"
    [[ -z "$name" ]] && echo "Использование: creature <имя>" && return 1
    local filepath="$SCRIPTS/$name"
    mkdir -p "$SCRIPTS"
    printf "#!/usr/bin/env zsh\n\n" > "$filepath"
    chmod +x "$filepath"
    if ! grep -q "alias $name=" ~/.zshrc 2>/dev/null; then
        echo "alias $name='$filepath'" >> ~/.zshrc
    fi
    ${EDITOR:-hx} "$filepath"
}

selection() {
    [[ $# -eq 0 ]] && echo "Использование: selection <файл>" && return 1
    local found_file=$(find "$HOME" -type f -name "$1" -print -quit 2>/dev/null)
    [[ -z "$found_file" ]] && echo "Не найден" && return 1
    chmod +x "$found_file"
    "$found_file" "${@:2}"
}

# === ИНИЦИАЛИЗАЦИЯ ===
clear
echo -e "\033[35m$(figlet -f slant -t -c "RUSH")\033[0m"
sep " " "$RUSH_VERS by General Spark Project"
sep "=" "FETCH"
command -v fastfetch &>/dev/null && fastfetch
sep "=" "SHELL"
