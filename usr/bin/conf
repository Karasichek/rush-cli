#!/usr/bin/env bash
export PREFIX="${PREFIX:-$HOME}"
export BINPATH="$PREFIX/usr/bin"
export FILPATH="$PREFIX/FIL"
export SCRIPTS="$PREFIX/usr/scripts"
export PATH="$BINPATH:$FILPATH:$SCRIPTS:$PATH"

mkdir -p "$SCRIPTS"
mkdir -p "$BINPATH"

creature() {
    local name="$1"
    local filepath="$SCRIPTS/$name"
    if [[ -z "$name" ]]; then
        echo "Использование: creature <имя_скрипта>"
        return 1
    fi
    mkdir -p "$SCRIPTS"
    echo "#!/usr/bin/env bash" > "$filepath"
    echo "" >> "$filepath"
    chmod +x "$filepath"
    if ! grep -q "alias $name=" ~/.bashrc 2>/dev/null; then
        echo "alias $name=\\'$filepath\\'" >> ~/.bashrc
        echo "Добавлен alias \'$name\' в ~/.bashrc"
    fi
    command -v micro &>/dev/null && micro "$filepath" || nano "$filepath"
    echo "Готово!"
}

# === ЗАМЕТКИ ===
note() {
    NOTES_DIR="$HOME/.notes"
    mkdir -p "$NOTES_DIR"
    if [[ -n "$1" ]]; then
        FILENAME="$1.txt"
    else
        FILENAME="$(date +%Y-%m-%d).txt"
    fi
    FULL_PATH="$NOTES_DIR/$FILENAME"
    micro "$FULL_PATH"
}

# === ВЫБОР И ЗАПУСК ФАЙЛА ===
selection() {
    if [ $# -eq 0 ]; then
        echo "Использование: selection <имя_файла> [аргументы...]"
        return 1
    fi
    local filename="$1"
    shift
    local found_file=$(find "$HOME" -type f -name "$filename" -print -quit 2>/dev/null)
    if [ -z "$found_file" ]; then
        echo "Файл \'$filename\' не найден в $HOME"
        return 1
    fi
    echo "Найден файл: $found_file"
    
    case "$found_file" in
        *.sh|*.zsh|*.bash) [ -r "$found_file" ] && bash "$found_file" "$@" ;;
        *.py) python3 "$found_file" "$@" ;;
        *.pl) perl "$found_file" "$@" ;;
        *.rb) ruby "$found_file" "$@" ;;
        *.lua) lua "$found_file" "$@" ;;
        *.js) node "$found_file" "$@" ;;
        *)
            case "$(head -n 1 "$found_file")" in
                *"/bin/sh"*|*"/bin/bash"*|*"/bin/zsh"*) bash "$found_file" "$@" ;;
                *"/bin/python"*) python3 "$found_file" "$@" ;;
                *) [ -x "$found_file" ] && "$found_file" "$@" || echo "Неподдерживаемый тип файла" ;;
            esac
            ;;
    esac
}

repo-check() {
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "Не в git-репозитории"
        return 2
    fi
    if ! git rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
        echo "Ветка не отслеживает удалённую"
        return 3
    fi
    git fetch origin 2>/dev/null
    LOCAL=$(git rev-parse @)
    REMOTE=$(git rev-parse @{u})
    if [ "$LOCAL" = "$REMOTE" ]; then
        echo "Всё актуально"
        return 0
    elif [ "$(git rev-list --count @{u}..@)" -gt 0 ]; then
        echo "Локальных коммитов больше, чем в origin"
        return 0
    else
        echo "Есть обновления!"
        return 1
    fi
}

repo-sync() {
    cd "$1" || return 1
    git fetch origin
    if ! git diff --quiet HEAD; then
        git add .
        git commit -m "$2" || return 1
        git push
        gh pr create --title "$3" --body "$2" 2>/dev/null || echo "PR may already exist"
    else
        echo "No changes to commit"
    fi
}

# === ИНИЦИАЛИЗАЦИЯ ===
clear
echo -e "\033[35m$(figlet -f slant -t -c "RUSH")\033[0m"
sep " " "0.1.4 by General Spark Project"
sep "=" "FETCH"
echo
command -v fastfetch &>/dev/null && fastfetch
echo
sep "=" "SHELL"
