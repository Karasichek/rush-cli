#!/usr/bin/env bash

# === ФУНКЦИИ ===
sep() {
    local char="${1:-=}"
    local text="$2"
    local width=$(tput cols 2>/dev/null || echo 80)
    if [[ -z "$text" ]]; then
        printf "%${width}s\n" | tr " " "$char"
    else
        echo "$text" | awk -v w="$width" -v c="$char" '{
            len=length($0);
            left=int((w-len-2)/2);
            right=w-len-2-left;
            for(i=0;i<left;i++) printf c;
            printf " %s ", $0;
            for(i=0;i<right;i++) printf c;
            print ""
        }'
    fi
}

site-check() {
    local sites=("google.com" "github.com" "yandex.ru")
    sep "=" "NETWORK"
    for site in "${sites[@]}"; do
        ping_output=$(ping -c 1 -W 1 "$site" 2>/dev/null)
        if [[ $? -eq 0 ]]; then
            if [[ "$ping_output" =~ time=([0-9.]+) ]]; then
                printf "[ \033[32mOK\033[0m ] %s — %s ms\n" "$site" "${BASH_REMATCH[1]}"
            else
                printf "[ \033[32mOK\033[0m ] %s\n" "$site"
            fi
        else
            printf "[ \033[31mFAIL\033[0m ] %s\n" "$site"
        fi
    done
    sep "="
}

creature() {
    local filepath="$SCRIPTS/$1"
    if [[ -z "$1" ]]; then
        echo "Использование: creature <имя_скрипта>"
        return 1
    fi
    mkdir -p "$SCRIPTS"
    touch "$filepath"
    echo "#!/usr/bin/env bash" > "$filepath"
    echo "" >> "$filepath"
    chmod +x "$filepath"
    if ! grep -q "alias $1=" ~/.bashrc 2>/dev/null; then
        echo "alias $1='$filepath'" >> ~/.bashrc
        echo "Добавлен alias '$1' в ~/.bashrc"
    fi
    command -v micro &>/dev/null && micro "$filepath" || nano "$filepath"
}

bandage() {
    local TARGET_FILE="${ALIAS_FILE:-${HOME}/usr/aliases.sh}"
    
    echo "╭" && sep "─" "Creating alias"
    
    echo -n "│ Alias name: "
    read -r ALIAS_NAME
    echo -n "│ For command: "
    read -r ALIAS_COMMAND
    echo -n "│ Some description: "
    read -r ALIAS_DESCRIPTION
    
    echo "╰" && sep "─" ""
    
    # Экранируем кавычки в команде
    local ESCAPED_COMMAND=$(printf "%q" "$ALIAS_COMMAND")
    local ALIAS_LINE="# ${ALIAS_NAME}: ${ALIAS_DESCRIPTION}\nalias ${ALIAS_NAME}=\"${ESCAPED_COMMAND}\""
    
    mkdir -p "$(dirname "$TARGET_FILE")"
    echo -e "\n${ALIAS_LINE}" >> "$TARGET_FILE"

    source "$TARGET_FILE" 2>/dev/null

    echo "Алиас '$ALIAS_NAME' добавлен в $TARGET_FILE"
}

view-docs() {
    local DOCS_DIR="${HOME}/rush-cli/site"
    if [ ! -d "$DOCS_DIR" ]; then
        echo "Документация не собрана. Запустите 'mkdocs build' в директории проекта."
        return 1
    fi
    
    local PORT=8080
    echo "Запуск сервера документации на http://localhost:$PORT"
    
    # Попытка открыть браузер (Termux / Linux / macOS)
    if command -v termux-open-url >/dev/null 2>&1; then
        termux-open-url "http://localhost:$PORT"
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "http://localhost:$PORT" >/dev/null 2>&1
    elif command -v open >/dev/null 2>&1; then
        open "http://localhost:$PORT"
    fi
    
    miniserve "$DOCS_DIR" -p "$PORT" --index index.html
}

# === ЗАМЕТКИ ===
note() {
    mkdir -p "$NOTES_FOLDER"
    if [[ -n "$1" ]]; then
        FILENAME="$1.txt"
    else
        FILENAME="$(date +%Y-%m-%d).txt"
    fi
    FULL_PATH="$NOTES_FOLDER/$FILENAME"
    micro "$FULL_PATH"
}

# === ВЫБОР И ЗАПУСК ФАЙЛА ===
selection() {
    if [ $# -eq 0 ]; then
        echo "Использование: selection <имя_файла> [аргументы...]"
        return 1
    fi
    local filename="$1"
    shift
    local found_file=$(find "$HOME" -type f -name "$filename" -print -quit 2>/dev/null)
    if [ -z "$found_file" ]; then
        echo "Файл '$filename' не найден в $HOME"
        return 1
    fi
    echo "Найден файл: $found_file"
    if [ -r "$found_file" ]; then
        chmod +x "$found_file"
        echo "Установлены права на выполнение"
    fi
    if [ -r "$found_file" ]; then
        local first_line=$(head -n 1 "$found_file")
        if [[ "$first_line" =~ ^#! ]]; then
            echo "Обнаружен shebang, запуск..."
            "$found_file" "$@"
            return $?
        fi
    fi
    local mime_type=$(file --mime-type -b "$found_file" 2>/dev/null)
    local extension="${found_file##*.}"
    case "$mime_type" in
        text/x-shellscript)
            echo "Запуск Shell скрипта..."
            bash "$found_file" "$@"
            ;;
        text/x-python|text/x-python3)
            echo "Запуск Python скрипта..."
            python3 "$found_file" "$@"
            ;;
        *)
            case "$extension" in
                py)     python3 "$found_file" "$@" ;;
                *)      command -v micro &>/dev/null && micro "$found_file" || nano "$found_file" ;;
            esac
            ;;
    esac
}

repo-check() {
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "Не в git-репозитории"
        return 2
    fi
    if ! git rev-parse --abbrev-ref @{u} >/dev/null 2>&1; then
        echo "Ветка не отслеживает удалённую"
        return 3
    fi
    git fetch origin 2>/dev/null
    LOCAL=$(git rev-parse @)
    REMOTE=$(git rev-parse @{u})
    if [ "$LOCAL" = "$REMOTE" ]; then
        echo "Всё актуально"
        return 0
    elif [ "$(git rev-list --count @{u}..@)" -gt 0 ]; then
        echo "Локальных коммитов больше, чем в origin"
        return 0
    else
        echo "Есть обновления!"
        return 1
    fi
}

repo-sync() {
    cd "$1" || return 1
    git fetch origin
    if ! git diff --quiet HEAD; then
        git add .
        git commit -m "$2" || return 1
        git push
        gh pr create --title "$3" --body "$2" 2>/dev/null || echo "PR may already exist"
    else
        echo "No changes to commit"
    fi
}

# === ИНИЦИАЛИЗАЦИЯ ===
clear
echo -e "\033[35m$(figlet -f slant -t -c "RUSH")\033[0m"
sep " " "0.1.4 by General Spark Project"
sep "=" "FETCH"
echo
command -v fastfetch &>/dev/null && fastfetch
echo
sep "=" "SHELL"
