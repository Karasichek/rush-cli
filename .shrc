#!/bin/sh

FLAG_FILE="$HOME/FLAG"
CONF_FILE="$HOME/usr/bin/conf"

chmod 700 ~/.ssh
chmod 600 ~/.ssh/id_ed25519
chmod 644 ~/.ssh/id_ed25519.pub

. "$HOME/usr/bin/SEARCH-FETCH-CONFIG"

# Исправлено: [[ ]] -> [ ]
if [ -f "$CONF_FILE" ]; then
    . "$CONF_FILE"
else
    echo "Конфиг не найден: $CONF_FILE"
fi

if [ ! -f "$FLAG_FILE" ]; then
    apt update && apt install -y tmux hx xmake rsync eza fastfetch ncurses-utils git figlet gh gitui fzf
    touch "$FLAG_FILE"
fi

# === АЛИАСЫ ===
alias blackout="env -u ENV dash"            
alias zshrc="hx ~/.shrc"            
alias config='hx "$HOME/usr/bin/conf"' 
alias reload="source ~/.shrc && tmux clear-history"        
alias backup='rsync -av --delete --inplace --no-owner --no-group --exclude=".cache" --exclude="tmp" --exclude="**/node_modules" ~/ /sdcard/termux/'
alias backfrom='rsync -av --delete --inplace --no-owner --no-group --chmod=ugo=rwX /sdcard/termux/ ~/'
alias bin='$HOME/usr/bin'

tmux